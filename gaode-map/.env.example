# ========================================
# FastAPI 高德地图扣子插件 环境配置
# ========================================

# 应用配置
# ---------------------------
# 应用主机地址
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000
# MySQL 数据库连接配置（必填）
# 格式: mysql+pymysql://用户名:密码@主机地址:端口/数据库名?charset=utf8mb4
DB_URL=mysql+pymysql://user:password@127.0.0.1:3306/gaode_map?charset=utf8mb4

# API密钥配置
# ---------------------------
API_KEYS=["replace-with-strong-api-key"]

# 文件保留时间
FILE_LIFETIME_HOURS=168
CLEANUP_INTERVAL_HOURS=24

# 高德地图API配置
# ---------------------------
AMAP_WEB_SERVICE_KEY=
AMAP_JS_API_KEY=
AMAP_JS_SECURITY_CODE=
TIANDITU_KEY=

# AI Agent provider 配置
# ---------------------------
# 启用后，Agent 会调用 LLM tool loop；当前默认接入 DeepSeek chat completions + tool calling。
AI_ENABLED=false
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_THINKING_ENABLED=true
AI_TIMEOUT_S=60
AI_MAX_CONTEXT_TURNS=12
AI_MAX_REPLANS=2

# 本地历史数据查询服务配置
# ---------------------------
# 完全 Docker 化：同一 compose 网络内访问 search 服务
LOCAL_QUERY_BASE_URL=http://search:8001
LOCAL_QUERY_COORD_SYSTEM=gcj02

# 等时圈（Isochrone）配置
# ---------------------------
ISOCHRONE_PROVIDER=valhalla
VALHALLA_BASE_URL=http://127.0.0.1:8002
VALHALLA_TIMEOUT_S=60
# 降低线程数以避免 Windows 下 "Two many open files" 错误
VALHALLA_SERVER_THREADS=2

# ArcGIS HTTP bridge
ARCGIS_BRIDGE_ENABLED=true
ARCGIS_BRIDGE_BASE_URL=http://host.docker.internal:18081
ARCGIS_BRIDGE_TOKEN=
ARCGIS_BRIDGE_TIMEOUT_S=300
ARCGIS_EXPORT_TIMEOUT_S=600
ARCGIS_EXPORT_MAX_MB=512
# Host bridge runtime (used by host_bridge service)
ARCGIS_TOKEN=
ARCGIS_PYTHON_PATH=C:\Python27\ArcGIS10.7\python.exe
ARCGIS_SCRIPT_PATH=D:\Coding\map_analyse\scripts\arcgis_h3_pipeline.py
ARCGIS_ROAD_SYNTAX_SDNA_SCRIPT_PATH=D:\Coding\map_analyse\scripts\arcgis_road_syntax_sdna_global.py
ARCGIS_BRIDGE_PORT=18081

# CORS跨域配置
# ---------------------------
CORS_ORIGINS=["*"]

# 本地路网同源配置（Valhalla + Overpass）
DEPTHMAPX_CLI_PATH=/usr/local/bin/depthmapXcli
OVERPASS_ENDPOINT=http://overpass/api/interpreter
ROAD_SYNTAX_GLOBAL_EDGE_CAP=18000
OVERPASS_PBF_FILE=hunan-260201.osm.pbf
VALHALLA_CUSTOM_FILES_DIR=D:/MapData/osm_source
VALHALLA_TILES_DIR=D:/MapData/valhalla_tiles
OVERPASS_DB_DIR=D:/MapData/overpass_db
OVERPASS_SOURCE_DIR=D:/MapData/osm_source
CITY_BOUNDARY_HOST_DIR=D:/MapData/boundaries
CITY_BOUNDARY_DIR=/mapdata/boundaries
POPULATION_DATA_HOST_DIR=E:/PeopleData
POPULATION_DATA_DIR=/mapdata/population
POPULATION_OUTPUT_DIR=/app/runtime/generated_population
POPULATION_PREVIEW_MAX_SIZE=2048
NIGHTLIGHT_DATA_HOST_DIR=E:/NightlightData
NIGHTLIGHT_DATA_DIR=/mapdata/nightlight/processed
NIGHTLIGHT_PREVIEW_MAX_SIZE=2048
